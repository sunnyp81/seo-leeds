---
import Base from '../layouts/Base.astro';

const title = "Contact SEO Leeds | Enquiries";
const description = "Contact SEO Leeds for a data-led proposal. Email hello@seo-leeds.uk. 92% of enquiries receive a response within 4 hours. Leeds, West Yorkshire, UK-wide.";

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://seo-leeds.uk/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Contact",
        "item": "https://seo-leeds.uk/contact/"
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Contact SEO Leeds",
    "description": "Contact SEO Leeds for a data-led SEO proposal. Covering Leeds, West Yorkshire, and the UK.",
    "url": "https://seo-leeds.uk/contact/",
    "isPartOf": {
      "@type": "WebSite",
      "name": "SEO Leeds",
      "url": "https://seo-leeds.uk"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is the typical response time for enquiries?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "92% of enquiries receive a reply within 4 working hours. All emails are answered within one business day. Initial strategy calls are scheduled within the same week."
        }
      },
      {
        "@type": "Question",
        "name": "Is there a cost for the initial consultation?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No. The initial consultation is complimentary. We assess your current search visibility, identify measurable opportunities, and outline projected outcomes before any engagement begins."
        }
      },
      {
        "@type": "Question",
        "name": "Do you work with businesses outside Leeds?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. SEO Leeds operates remote-first and serves clients UK-wide. Our deepest competitive intelligence covers Leeds and West Yorkshire, but our methodology applies to any UK market."
        }
      },
      {
        "@type": "Question",
        "name": "What information should I include in my enquiry?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Your website URL and primary business objective. Google Search Console or Analytics access accelerates the assessment but is not required. We extract actionable data from public sources in the first instance."
        }
      }
    ]
  }
];
---

<Base title={title} description={description} schema={schema}>
  <section class="px-4 py-12">
    <div class="prose">
      <h1>Contact SEO Leeds</h1>

      <p>SEO Leeds delivers measurable organic growth for businesses across Leeds, West Yorkshire, and the UK. Every engagement begins with data. Send one email and receive a preliminary search assessment within 24 hours.</p>

      <div class="quick-answer">
        <p>Email <strong>hello@seo-leeds.uk</strong> — 92% of enquiries receive a response within 4 working hours. No sales pitch. No obligation. Direct access to the strategists who execute the work.</p>
      </div>

      <h2>How to Reach Us</h2>

      <p>Email is the primary channel. Send your enquiry to <strong>hello@seo-leeds.uk</strong> with your website URL and a brief description of what you want to achieve. We reply with an initial performance snapshot and recommended next steps.</p>

      <p>Detail level is your choice. A single sentence works. So does a full competitive brief with analytics access and target keyword lists. The objective is the same: establish baseline metrics and identify the highest-impact opportunities for your business.</p>

      <p>Every enquiry receives a direct response from a senior strategist. There is no account management layer between you and the people analysing your data.</p>

      <h2>Coverage Area</h2>

      <p>SEO Leeds provides <a href="/services/">SEO services</a> across the following regions:</p>

      <ul>
        <li><strong>Leeds city centre</strong> — Wellington Place, Park Square, East Parade, Victoria Quarter, Trinity Leeds, Leeds Dock, South Bank, financial district</li>
        <li><strong>Leeds suburbs</strong> — Headingley, Chapel Allerton, Roundhay, Horsforth, Meanwood, Morley, Pudsey, Garforth, Rothwell, Wetherby, all LS postcodes</li>
        <li><strong>West Yorkshire</strong> — Bradford, Wakefield, Huddersfield, Halifax, Dewsbury, and surrounding towns</li>
        <li><strong>Northern England and UK-wide</strong> — York, Harrogate, Sheffield, Manchester, and national campaigns for businesses targeting broader markets</li>
      </ul>

      <p>Remote-first operations remove geographic constraints. We serve clients across the UK. However, our competitive intelligence, local search data, and market benchmarks run deepest in Leeds and West Yorkshire. If your customers search in this region, our data advantage is significant. See our <a href="/areas/">areas page</a> for detailed coverage.</p>

      <h2>The Process</h2>

      <ol>
        <li><strong>Strategy call.</strong> A 20-minute conversation covering your business model, current search performance, and commercial objectives. Complimentary. No presentation decks.</li>
        <li><strong>Performance assessment.</strong> We deliver a data-backed view of your organic position: indexation health, keyword gaps, competitor benchmarks, and quick-win opportunities identified from Search Console data and public SERP analysis.</li>
        <li><strong>Proposal.</strong> Defined scope, timeline, deliverables, and <a href="/seo-pricing-leeds/">pricing</a>. No lock-in contracts. No ambiguous retainer terms. Every line item is measurable.</li>
        <li><strong>Your timeline.</strong> There is no pressure to commit. Some clients engage within 48 hours. Others evaluate over several weeks. The proposal remains valid for 30 days.</li>
      </ol>

      <p>Want data before we speak? Request the <a href="/free-seo-audit-leeds/">free SEO audit</a> and receive a preliminary analysis of your site within one business day.</p>

      <h2>Find Us</h2>

      <p>SEO Leeds is a remote-first consultancy covering the Leeds metropolitan area and beyond. The map below shows our primary service region.</p>

      <div style="margin: 1.5rem 0; overflow: hidden; border: 2px solid var(--color-border);">
        <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d37832.77925989498!2d-1.5767!3d53.7997!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x48795c6c42ec2a79%3A0x444aa3eae68b3e8!2sLeeds!5e0!3m2!1sen!2suk!4v1" width="100%" height="400" style="border:0;" loading="lazy" title="SEO Leeds coverage area — Leeds city centre"></iframe>
      </div>

      <h2>Frequently Asked Questions</h2>

      <div class="faq-item">
        <h3>What is the typical response time for enquiries?</h3>
        <p>92% of enquiries receive a reply within 4 working hours. All emails are answered within one business day. Initial strategy calls are scheduled within the same week.</p>
      </div>

      <div class="faq-item">
        <h3>Is there a cost for the initial consultation?</h3>
        <p>No. The initial consultation is complimentary. We assess your current search visibility, identify measurable opportunities, and outline projected outcomes before any engagement begins.</p>
      </div>

      <div class="faq-item">
        <h3>Do you work with businesses outside Leeds?</h3>
        <p>Yes. SEO Leeds operates remote-first and serves clients UK-wide. Our deepest competitive intelligence covers Leeds and West Yorkshire, but our methodology applies to any UK market.</p>
      </div>

      <div class="faq-item">
        <h3>What information should I include in my enquiry?</h3>
        <p>Your website URL and primary business objective. Google Search Console or Analytics access accelerates the assessment but is not required. We extract actionable data from public sources in the first instance.</p>
      </div>

      <div class="cta-box">
        <h2 style="color: white; margin-top: 0;">Request a Proposal</h2>
        <p>Email hello@seo-leeds.uk with your URL. Receive a data-backed assessment within one business day. No obligation.</p>
        <a href="mailto:hello@seo-leeds.uk">Request a Proposal</a>
      </div>

      <p style="text-align: center; margin-top: 2rem;"><a href="/">Home</a> | <a href="/services/">Services</a> | <a href="/about/">About</a> | <a href="/seo-pricing-leeds/">Pricing</a></p>
    </div>
  </section>
</Base>
