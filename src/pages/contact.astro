---
import Base from '../layouts/Base.astro';

const title = "Contact Aire SEO | Get in Touch";
const description = "Contact Aire SEO for a free consultation. Covering Leeds, West Yorkshire, and the Northern Powerhouse. Email hello@seo-leeds.uk to start.";

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://seo-leeds.uk/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Contact",
        "item": "https://seo-leeds.uk/contact/"
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Contact Aire SEO",
    "description": "Contact Aire SEO for a free consultation. Covering Leeds, West Yorkshire, and the Northern Powerhouse.",
    "url": "https://seo-leeds.uk/contact/",
    "isPartOf": {
      "@type": "WebSite",
      "name": "Aire SEO",
      "url": "https://seo-leeds.uk"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How fast will you respond?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Within one working day, usually within a few hours during business hours. Initial consultations are booked within the same week."
        }
      },
      {
        "@type": "Question",
        "name": "Do you offer free consultations?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. Every engagement starts with a free, no-obligation consultation. We review your search performance, discuss objectives, and outline what SEO can realistically deliver before any commitment."
        }
      },
      {
        "@type": "Question",
        "name": "Do I need to be based in Leeds?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No. We specialise in Leeds and West Yorkshire SEO but work with businesses across the UK. Remote-first means location is not a barrier. Our deepest market knowledge is in the Leeds region."
        }
      },
      {
        "@type": "Question",
        "name": "What should I prepare before getting in touch?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Ideally your website URL, a rough idea of target services or keywords, and any Google Search Console or Analytics access. But none of that is required — we can work through everything together."
        }
      }
    ]
  }
];
---

<Base title={title} description={description} schema={schema}>
  <section class="px-4 py-12">
    <div class="prose">
      <h1>Contact Aire SEO</h1>

      <p>Aire SEO is a remote-first search marketing agency covering Leeds, West Yorkshire, and the wider Northern Powerhouse. Whether you run a professional services firm in the city centre, a restaurant in Headingley, or an e-commerce operation shipping from South Bank — getting in touch is the first step toward understanding what organic search can do for your revenue.</p>

      <div class="quick-answer">
        <p>Email <strong>hello@seo-leeds.uk</strong> for a free, no-obligation consultation. We respond within one working day. No hard sell, no jargon — just a straight conversation about your business.</p>
      </div>

      <h2>Reach Us</h2>

      <p>Email is the fastest route. Send your enquiry to <strong>hello@seo-leeds.uk</strong> with a brief description of your business, your website URL, and what you want to achieve through SEO. We will reply within one working day with an initial assessment and next steps.</p>

      <p>Keep it as brief or detailed as you like. Some clients send a single line — "I need SEO help for my Leeds business" — and we take it from there. Others provide competitor lists, analytics access, and specific ranking targets. Both work. The point is starting the conversation.</p>

      <p>Every enquiry gets a direct response from our team. No junior account managers, no shuffling between departments. The people you speak to are the people doing the work.</p>

      <h2>Coverage Area</h2>

      <p>Aire SEO provides <a href="/services/">SEO services</a> across:</p>

      <ul>
        <li><strong>Leeds city centre</strong> — financial district, Wellington Place, Park Square, East Parade, Victoria Quarter, Trinity Leeds, Leeds Dock, South Bank</li>
        <li><strong>Leeds suburbs</strong> — Headingley, Chapel Allerton, Roundhay, Horsforth, Meanwood, Morley, Pudsey, Garforth, Rothwell, Wetherby, all LS postcodes</li>
        <li><strong>West Yorkshire</strong> — Bradford, Wakefield, Huddersfield, Halifax, Dewsbury, surrounding towns</li>
        <li><strong>Northern Powerhouse</strong> — York, Harrogate, Sheffield, Manchester, and the wider North for regional or national SEO</li>
      </ul>

      <p>Remote-first means we are not constrained by geography. We work UK-wide. But our deepest market knowledge, local connections, and competitive intelligence sit in Leeds and West Yorkshire. If your customers are here, we understand your search landscape better than any London agency parachuting into the Northern market. See our <a href="/areas/">areas page</a> for more.</p>

      <h2>What Happens Next</h2>

      <ol>
        <li><strong>Initial call.</strong> 20-30 minutes to understand your business, goals, and current search performance. Free. No pitch deck, no pressure — just a practical discussion.</li>
        <li><strong>Preliminary assessment.</strong> We deliver an initial view of your SEO situation: what works, what does not, where the biggest opportunities sit. Quick wins and structural issues identified from a brief review of your site and Search Console data.</li>
        <li><strong>Proposal.</strong> Clear scope, timeline, deliverables, and <a href="/seo-pricing-leeds/">pricing</a>. No lock-in contracts, no hidden fees, no ambiguous retainer scopes. You know exactly what you get and what it costs.</li>
        <li><strong>Your timeline.</strong> No pressure to commit immediately. Some clients start the same week. Others take a month. We are here when you are ready.</li>
      </ol>

      <p>Want a head start? Grab the <a href="/free-seo-audit-leeds/">free SEO audit</a> and we will send you an initial analysis before we even speak.</p>

      <h2>Find Us</h2>

      <p>Aire SEO is a remote-first agency covering the Leeds metropolitan area and beyond. The map below shows our primary coverage area.</p>

      <div style="margin: 1.5rem 0; overflow: hidden; border: 2px solid var(--color-border);">
        <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d37832.77925989498!2d-1.5767!3d53.7997!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x48795c6c42ec2a79%3A0x444aa3eae68b3e8!2sLeeds!5e0!3m2!1sen!2suk!4v1" width="100%" height="400" style="border:0;" loading="lazy" title="Aire SEO coverage area — Leeds city centre"></iframe>
      </div>

      <h2>Frequently Asked Questions</h2>

      <div class="faq-item">
        <h3>How fast will you respond?</h3>
        <p>Within one working day, usually within a few hours during business hours. Initial consultations booked within the same week.</p>
      </div>

      <div class="faq-item">
        <h3>Do you offer free consultations?</h3>
        <p>Yes. Every engagement starts free and no-obligation. We review your search performance, discuss goals, and outline what SEO can realistically deliver — before any commitment.</p>
      </div>

      <div class="faq-item">
        <h3>Do I need to be based in Leeds?</h3>
        <p>No. We specialise in Leeds and West Yorkshire but work UK-wide. Remote-first means location is never a barrier. Our deepest knowledge is in the Leeds region.</p>
      </div>

      <div class="faq-item">
        <h3>What should I prepare before getting in touch?</h3>
        <p>Your website URL, a rough idea of target <a href="/services/">services</a> or keywords, and any Search Console or Analytics access. But none of that is required — we work through everything together.</p>
      </div>

      <div class="cta-box">
        <h2 style="color: white; margin-top: 0;">Let's Talk</h2>
        <p>Email hello@seo-leeds.uk for a free consultation. No obligation — just a direct conversation about what SEO can do for your Leeds business.</p>
        <a href="mailto:hello@seo-leeds.uk">Get the Audit</a>
      </div>

      <p style="text-align: center; margin-top: 2rem;"><a href="/">Home</a> | <a href="/services/">Services</a> | <a href="/about/">About</a> | <a href="/seo-pricing-leeds/">Pricing</a></p>
    </div>
  </section>
</Base>
