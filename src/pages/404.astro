---
import Base from '../layouts/Base.astro';
---

<Base title="Page Not Found — SEO Leeds" description="The page you're looking for doesn't exist. Return to SEO Leeds homepage.">
  <section class="px-4 py-20 text-center">
    <div class="prose mx-auto">
      <h1 class="text-4xl font-bold text-brand mb-4">Page Not Found</h1>
      <p class="text-lg text-text-muted mb-8">The page you're looking for doesn't exist or has been moved.</p>
      <a href="/" class="inline-block bg-brand text-white font-bold px-6 py-3 rounded-lg hover:bg-brand-light transition-colors">
        Return to Homepage
      </a>
    </div>
  </section>
</Base>
